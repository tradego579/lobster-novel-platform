# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
DATABASE_URL="postgresql://novel:novel123456@localhost:5432/novel_platform"

# ==================== Redis 配置 ====================
REDIS_URL="redis://localhost:6379"

# ==================== Meilisearch 配置 ====================
MEILI_URL="http://localhost:7700"
MEILI_KEY="novel_master_key_123"

# ==================== 应用配置 ====================
NEXT_PUBLIC_APP_NAME="小牛马小说平台"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ==================== JWT 配置 ====================
JWT_SECRET="your_jwt_secret_key_change_in_production"
JWT_EXPIRES_IN="7d"

# ==================== 文件存储配置 ====================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE="10485760"

# ==================== 飞书集成配置 (可选) ====================
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_VERIFICATION_TOKEN=""

# ==================== 邮件配置 (可选) ====================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ==================== 对象存储配置 (可选) ====================
OSS_ENDPOINT=""
OSS_BUCKET=""
OSS_ACCESS_KEY=""
OSS_ACCESS_SECRET=""
